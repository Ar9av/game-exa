    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.1",
    "consola": "^3.4.2",
    "cosmiconfig": "^9.0.0",
    "picocolors": "^1.1.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  }
}
