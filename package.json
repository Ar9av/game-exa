{
  "name": "gameforge",
  "version": "0.1.0",
  "description": "A pluggable skill pack that lets any coding agent turn a one-line description into a runnable Phaser 3 game.",
  "type": "module",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/Ar9av/gameforge.git" },
  "homepage": "https://github.com/Ar9av/gameforge#readme",
  "bugs":     { "url": "https://github.com/Ar9av/gameforge/issues" },
  "keywords": ["phaser", "game-engine", "agent", "claude-code", "skill", "pixel-art", "generative"],
  "engines": { "node": ">=20.11" },
