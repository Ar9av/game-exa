{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GameDesignDocument",
  "type": "object",
  "required": ["title", "genre", "loop", "winCondition", "loseCondition", "controls", "entities", "tilesetPalette", "levelHints"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 40 },
    "genre": { "enum": ["top-down-adventure", "platformer", "twin-stick-shooter", "puzzle", "shoot-em-up", "dungeon-crawler"] },
    "tagline": { "type": "string" },
    "loop": { "type": "string" },
    "winCondition": { "type": "string" },
    "loseCondition": { "type": "string" },
    "controls": {
      "type": "object",
      "required": ["movement", "actions"],
      "properties": {
        "movement": { "enum": ["8-direction", "4-direction", "platformer", "twin-stick"] },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "name", "description"],
            "properties": {
              "key": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["id", "kind", "color", "desc", "states", "speed", "hp"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "kind": { "enum": ["player", "enemy", "npc", "pickup", "projectile", "boss"] },
          "color": { "type": "string" },
          "desc": { "type": "string" },
          "states": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z]+$" },
            "contains": { "const": "idle" }
          },
          "speed": { "type": "number", "minimum": 0 },
          "hp": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "tilesetPalette": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "color", "passable"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "passable": { "type": "boolean" }
        }
      }
    },
    "levelHints": {
      "type": "object",
      "required": ["size", "count", "themes"],
      "properties": {
        "size": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 8, "maximum": 40 }
        },
        "count": { "type": "integer", "minimum": 1, "maximum": 3 },
        "themes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
