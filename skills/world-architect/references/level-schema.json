{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LevelArray",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "size", "tiles", "spawns"],
    "properties": {
      "id":    { "type": "string" },
      "theme": { "type": "string" },
      "size":  {
        "type": "array",
        "minItems": 2, "maxItems": 2,
        "items": { "type": "integer", "minimum": 8, "maximum": 40 }
      },
      "tiles": {
        "type": "array",
        "items": { "type": "array", "items": { "type": "integer", "minimum": 0 } }
      },
      "spawns": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["entity", "x", "y"],
          "properties": {
            "entity": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
            "x":      { "type": "integer", "minimum": 0 },
            "y":      { "type": "integer", "minimum": 0 },
            "facing": { "enum": ["up", "down", "left", "right"] }
          }
        }
      },
      "goal": {
        "type": "object",
        "properties": {
          "kind":     { "enum": ["tile", "entity"] },
          "x":        { "type": "integer" },
          "y":        { "type": "integer" },
          "entityId": { "type": "string" }
        }
      }
    }
  }
}
